#usda 1.0
(
    defaultPrim = "Asset"
    metersPerUnit = 0.01
    upAxis = "Y"
)

def Xform "Asset" (
    prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
)
{
    bool physics:rigidBodyEnabled = 1
    float physics:mass = 2.5

    def Mesh "Tetrahedron" (
        prepend apiSchemas = ["PhysicsCollisionAPI"]
    )
    {
        int[] faceVertexCounts = [3, 3, 3, 3]
        int[] faceVertexIndices = [0, 2, 1, 0, 1, 3, 0, 3, 2, 1, 2, 3]
        point3f[] points = [(0, 0, 0), (100, 0, 0), (0, 100, 0), (0, 0, 100)]
        color3f[] primvars:displayColor = [(0.2, 0.65, 0.85)]
        uniform token subdivisionScheme = "none"
    }
}

def Material "PhysicsMaterial" (
    prepend apiSchemas = ["PhysicsMaterialAPI"]
)
{
    float physics:dynamicFriction = 0.42
    float physics:staticFriction = 0.5
    float physics:restitution = 0.15
}
