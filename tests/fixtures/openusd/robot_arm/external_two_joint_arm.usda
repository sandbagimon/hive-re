#usda 1.0
(
    defaultPrim = "ExternalArm"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "ExternalArm" (
    prepend apiSchemas = ["PhysicsArticulationRootAPI"]
)
{
    def Xform "Pedestal" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        point3f physics:centerOfMass = (0, 0, 0.1)
        float3 physics:diagonalInertia = (0.025, 0.025, 0.04)
        float physics:mass = 4

        def Cube "Appearance"
        {
            color3f[] primvars:displayColor = [(0.18, 0.22, 0.28)]
            double size = 1
            float3 xformOp:scale = (0.4, 0.4, 0.2)
            double3 xformOp:translate = (0, 0, 0.1)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "ContactShape" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1
            token visibility = "invisible"
            float3 xformOp:scale = (0.4, 0.4, 0.2)
            double3 xformOp:translate = (0, 0, 0.1)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }
    }

    def Xform "FirstSegment" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        point3f physics:centerOfMass = (0, 0, 0.3)
        float3 physics:diagonalInertia = (0.065, 0.065, 0.008)
        float physics:mass = 2
        double3 xformOp:translate = (0, 0, 0.2)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        def Cube "Appearance"
        {
            color3f[] primvars:displayColor = [(0.72, 0.22, 0.12)]
            double size = 1
            float3 xformOp:scale = (0.12, 0.12, 0.6)
            double3 xformOp:translate = (0, 0, 0.3)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "ContactShape" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1
            token visibility = "invisible"
            float3 xformOp:scale = (0.12, 0.12, 0.6)
            double3 xformOp:translate = (0, 0, 0.3)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }
    }

    def Xform "SecondSegment" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        point3f physics:centerOfMass = (0, 0, 0.25)
        float3 physics:diagonalInertia = (0.028, 0.028, 0.005)
        float physics:mass = 1.25
        double3 xformOp:translate = (0, 0, 0.8)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        def Cube "Appearance"
        {
            color3f[] primvars:displayColor = [(0.88, 0.38, 0.12)]
            double size = 1
            float3 xformOp:scale = (0.1, 0.1, 0.5)
            double3 xformOp:translate = (0, 0, 0.25)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }

        def Cube "ContactShape" (
            prepend apiSchemas = ["PhysicsCollisionAPI"]
        )
        {
            double size = 1
            token visibility = "invisible"
            float3 xformOp:scale = (0.1, 0.1, 0.5)
            double3 xformOp:translate = (0, 0, 0.25)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
        }
    }

    def "Constraints"
    {
        def PhysicsFixedJoint "Anchor"
        {
            rel physics:body1 = </ExternalArm/Pedestal>
        }

        def PhysicsRevoluteJoint "AxisA" (
            prepend apiSchemas = ["PhysicsDriveAPI:angular"]
        )
        {
            float drive:angular:physics:damping = 12
            float drive:angular:physics:maxForce = 80
            float drive:angular:physics:stiffness = 120
            float drive:angular:physics:targetPosition = 0
            uniform token drive:angular:physics:type = "force"
            uniform token physics:axis = "Y"
            rel physics:body0 = </ExternalArm/Pedestal>
            rel physics:body1 = </ExternalArm/FirstSegment>
            point3f physics:localPos0 = (0, 0, 0.2)
            point3f physics:localPos1 = (0, 0, 0)
            float physics:lowerLimit = -90
            float physics:upperLimit = 90
        }

        def PhysicsRevoluteJoint "AxisB" (
            prepend apiSchemas = ["PhysicsDriveAPI:angular"]
        )
        {
            float drive:angular:physics:damping = 9
            float drive:angular:physics:maxForce = 50
            float drive:angular:physics:stiffness = 90
            float drive:angular:physics:targetPosition = -22.918312
            uniform token drive:angular:physics:type = "force"
            uniform token physics:axis = "Y"
            rel physics:body0 = </ExternalArm/FirstSegment>
            rel physics:body1 = </ExternalArm/SecondSegment>
            point3f physics:localPos0 = (0, 0, 0.6)
            point3f physics:localPos1 = (0, 0, 0)
            float physics:lowerLimit = -126.05071
            float physics:upperLimit = 11.459156
        }
    }
}
