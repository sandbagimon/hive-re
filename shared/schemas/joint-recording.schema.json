{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simlab.local/schemas/joint-recording.schema.json",
  "title": "SimLabJointStateRecording",
  "$defs": {
    "jointState": {
      "type": "object",
      "properties": {
        "qpos": { "type": "number" },
        "qvel": { "type": "number" }
      },
      "required": ["qpos", "qvel"],
      "additionalProperties": false
    },
    "actuatorState": {
      "type": "object",
      "properties": {
        "ctrl": { "type": "number" },
        "force": { "type": "number" }
      },
      "required": ["ctrl", "force"],
      "additionalProperties": false
    },
    "jointSensorState": {
      "type": "object",
      "properties": {
        "sensor_type": { "const": "joint_state" },
        "joint_id": { "type": "string", "minLength": 1 },
        "time": { "type": "number", "minimum": 0 },
        "sequence": { "type": "integer", "minimum": 0 },
        "qpos": { "type": "number" },
        "qvel": { "type": "number" }
      },
      "required": ["sensor_type", "joint_id", "time", "sequence", "qpos", "qvel"],
      "additionalProperties": false
    },
    "imuSensorState": {
      "type": "object",
      "properties": {
        "sensor_type": { "const": "imu" },
        "link_id": { "type": "string", "minLength": 1 },
        "time": { "type": "number", "minimum": 0 },
        "sequence": { "type": "integer", "minimum": 0 },
        "orientation": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
        "angular_velocity": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
        "linear_acceleration": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
      },
      "required": ["sensor_type", "link_id", "time", "sequence", "orientation", "angular_velocity", "linear_acceleration"],
      "additionalProperties": false
    },
    "sensorState": {
      "oneOf": [
        { "$ref": "#/$defs/jointSensorState" },
        { "$ref": "#/$defs/imuSensorState" }
      ]
    },
    "sample": {
      "type": "object",
      "properties": {
        "time": { "type": "number", "minimum": 0 },
        "joints": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/jointState" }
        },
        "actuators": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/actuatorState" }
        },
        "sensors": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/sensorState" }
        }
      },
      "required": ["time", "joints", "actuators", "sensors"],
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "version": { "const": "1.0" },
    "name": { "type": "string", "minLength": 1 },
    "manifest": {
      "type": "object",
      "properties": {
        "engine": { "const": "mujoco" },
        "engine_version": { "type": "string", "minLength": 1 },
        "timestep": { "type": "number", "exclusiveMinimum": 0 },
        "scene_version": { "type": "string", "minLength": 1 }
      },
      "required": ["engine", "engine_version", "timestep", "scene_version"],
      "additionalProperties": false
    },
    "joint_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "actuator_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "sensor_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "sensor_types": {
      "type": "object",
      "additionalProperties": { "enum": ["joint_state", "imu"] }
    },
    "limit_reached": { "type": "boolean" },
    "samples": { "type": "array", "items": { "$ref": "#/$defs/sample" } }
  },
  "required": ["version", "name", "manifest", "joint_ids", "actuator_ids", "sensor_ids", "sensor_types", "limit_reached", "samples"],
  "additionalProperties": false
}
