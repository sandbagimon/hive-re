{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simlab.local/schemas/bridge-protocol.schema.json",
  "title": "SimLabBridgeProtocol",
  "$defs": {
    "rpcResult": {
      "type": "object",
      "properties": {
        "ok": { "type": "boolean" },
        "data": {},
        "error": { "type": ["string", "null"] }
      },
      "required": ["ok"],
      "additionalProperties": false
    },
    "validationIssue": {
      "type": "object",
      "properties": {
        "severity": { "enum": ["error", "warning"] },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "actor_id": { "type": ["string", "null"] },
        "actor_name": { "type": ["string", "null"] },
        "field": { "type": ["string", "null"] }
      },
      "required": ["severity", "code", "message"],
      "additionalProperties": false
    },
    "simulationState": {
      "type": "object",
      "properties": {
        "time": { "type": "number" },
        "actors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "position": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 3,
                "maxItems": 3
              },
              "quaternion": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 4,
                "maxItems": 4
              }
            },
            "required": ["id", "position", "quaternion"],
            "additionalProperties": false
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "position": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
              "quaternion": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 }
            },
            "required": ["id", "position", "quaternion"],
            "additionalProperties": false
          }
        },
        "joints": { "type": "array" },
        "actuators": { "type": "array" },
        "sensors": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "sensor_type": { "const": "joint_state" },
                  "joint_id": { "type": "string" },
                  "time": { "type": "number", "minimum": 0 },
                  "sequence": { "type": "integer", "minimum": 0 },
                  "qpos": { "type": "number" },
                  "qvel": { "type": "number" }
                },
                "required": ["id", "sensor_type", "joint_id", "time", "sequence", "qpos", "qvel"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "sensor_type": { "const": "imu" },
                  "link_id": { "type": "string" },
                  "time": { "type": "number", "minimum": 0 },
                  "sequence": { "type": "integer", "minimum": 0 },
                  "orientation": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
                  "angular_velocity": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
                  "linear_acceleration": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 }
                },
                "required": ["id", "sensor_type", "link_id", "time", "sequence", "orientation", "angular_velocity", "linear_acceleration"],
                "additionalProperties": false
              }
            ]
          }
        },
        "trajectory": {
          "type": "object",
          "properties": {
            "status": { "enum": ["stopped", "playing", "paused", "completed"] },
            "time": { "type": "number", "minimum": 0 },
            "duration": { "type": "number", "minimum": 0 },
            "name": { "type": ["string", "null"] }
          },
          "required": ["status", "time", "duration", "name"],
          "additionalProperties": false
        },
        "recording": {
          "type": "object",
          "properties": {
            "active": { "type": "boolean" },
            "sample_count": { "type": "integer", "minimum": 0 },
            "sensor_event_count": { "type": "integer", "minimum": 0 },
            "limit_reached": { "type": "boolean" },
            "name": { "type": ["string", "null"] }
          },
          "required": ["active", "sample_count", "sensor_event_count", "limit_reached", "name"],
          "additionalProperties": false
        },
        "controller": {
          "type": "object",
          "properties": {
            "status": { "enum": ["ready", "active", "timed_out", "fault"] },
            "message": { "type": ["string", "null"] },
            "command_time": { "type": ["number", "null"] },
            "timeout": { "type": ["number", "null"] }
          },
          "required": ["status", "message", "command_time", "timeout"],
          "additionalProperties": false
        }
      },
      "required": ["time", "actors", "links", "joints", "actuators", "sensors", "trajectory", "recording", "controller"],
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "rpc_methods": {
      "type": "array",
      "const": [
        "getAssets",
        "importOpenUsd",
        "importOpenUsdPath",
        "getVisualGeometry",
        "openProject",
        "openProjectPath",
        "saveProject",
        "saveProjectPath",
        "exportMjcf",
        "preflight",
        "runSimulation",
        "pauseSimulation",
        "stepSimulation",
        "resetSimulation",
        "setJointTargets",
        "loadTrajectory",
        "playTrajectory",
        "pauseTrajectory",
        "stopTrajectory",
        "startRecording",
        "stopRecording",
        "getRecording",
        "exportRecording",
        "exportRecordingDialog",
        "setEditorState"
      ]
    },
    "events": {
      "type": "array",
      "const": ["simulationStateChanged", "simulationStatusChanged", "consoleMessage"]
    },
    "result": { "$ref": "#/$defs/rpcResult" }
  },
  "required": ["rpc_methods", "events"],
  "additionalProperties": false
}
